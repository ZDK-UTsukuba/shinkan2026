---
import { CATEGORY_LIST } from "../consts";
import type { OrganizationCategory } from "../types";
import { lookupOrganizationCategoryName } from "../utils/organization";

export type Props = {
  text?: string | null;
  categories: OrganizationCategory[];
  faves?: string | null;
};

const { text, categories, faves } = Astro.props;

const counts: any = process.env.CATEGORY_COUNTS ?? [];
---

<form class="search container">
  <span class="limit"></span>
  <fieldset class="keyword">
    <input type="text" name="q" size="10" placeholder="団体名・キーワードでフィルタ" value={text} />
    <input type="submit" value="検索" />
  </fieldset>
  <fieldset class="filter">
    {
      CATEGORY_LIST.map((category) => (
        <label for={category}>
          <input
            type="checkbox"
            id={category}
            value={category}
            name="c[]"
            checked={categories?.length === 0 || categories.includes(category)}
          />
          <span>{`${lookupOrganizationCategoryName(category)} (${counts[category]})`}</span>
        </label>
      ))
    }
    <label for="faves">
      <input type="checkbox" id="faves" name="f" value="1" checked={Boolean(faves)} />
      <span id="faves-label">お気に入り</span>
    </label>
  </fieldset>
</form>

<style>
  .search {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    margin-block-end: 2rem;
  }
  .search .limit {
    content: "";
    position: absolute;
    top: -2px;
    left: 0;
    width: 100%;
    height: 1px;
    background: transparent;
  }
  .keyword {
    width: 100%;
    font-size: 0.875rem;
    display: flex;
  }
  input[type="text"] {
    display: flex;
    height: 2rem;
    padding: 0.5rem;
    align-items: center;
    border-radius: 0.75rem 0rem 0rem 0.25rem;
    border: 1px solid #f3e9e3;
    background: rgba(243, 233, 227, 0.5);
    flex: 1 0 0;
    flex-grow: 1;
  }
  input[type="submit"] {
    display: flex;
    color: #fff;
    width: 5rem;
    height: 2rem;
    padding: 0.5rem;
    justify-content: center;
    align-items: center;
    border-radius: 0rem 0.25rem 0.75rem 0rem;
    border: 1px solid var(--accent);
    flex-shrink: 0;
    background: var(--accent-bright);
    line-height: 1;
    text-align: center;
    transition: all 0.2s;
  }
  input[type="submit"]:hover {
    background: var(--accent);
  }
  .filter {
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1rem;
  }
  label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    color: #000;
    font-size: 1rem;
    font-weight: 400;
    line-height: normal;
  }
  input[type="checkbox"] {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 0.125rem;
    background: #f3e9e3;
    cursor: pointer;
  }
  input[type="checkbox"]:checked {
    background: var(--accent);
  }
  @media screen and (max-width: 670px), screen and (max-height: 440px) {
    .search {
      position: sticky;
      padding-block: 1rem;
      top: 0;
      z-index: 300;
      background: #fff;
      margin-block-end: 1rem;
    }
    .fixed {
      box-shadow: #0000001a 0 1px 4px;
    }
  }
</style>

<script>
  import { buildSearchAliases, normalizeSearchText } from "../utils/search";
  import { loadFavoriteGroups } from "../lib/fav";

  const search = document.querySelector(".search")! as HTMLFormElement;
  const text = search.querySelector('.keyword input[type="text"]')! as HTMLInputElement;
  const categoryInputs = [...search.querySelectorAll('input[name="c[]"]')] as HTMLInputElement[];
  const favoriteCheckbox = search.querySelector("#faves")! as HTMLInputElement;
  const label = search.querySelector("#faves-label")!;
  const grid = document.querySelector("[data-org-grid]")! as HTMLElement;
  const loading = document.querySelector("[data-search-loading]")! as HTMLElement;
  const emptyState = document.querySelector("[data-search-empty]")! as HTMLElement;
  const cards = [...grid.querySelectorAll("[data-org-card]")] as HTMLElement[];
  const originalOrderIds = cards.map((card) => card.dataset.orgId!).filter(Boolean);
  const cardMap = new Map(cards.map((card) => [card.dataset.orgId!, card]));
  const isInitialPending = grid.dataset.initialSearchPending === "true";

  const observer = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      if (entry.isIntersecting) {
        search.classList.remove("fixed");
      } else {
        search.classList.add("fixed");
      }
    }
  });

  observer.observe(document.querySelector(".search .limit")!);

  const getFavoriteIds = () => loadFavoriteGroups();

  const updateFavoriteLabel = () => {
    label.textContent = `お気に入り (${getFavoriteIds().size})`;
  };

  updateFavoriteLabel();

  // @ts-ignore
  const pagefind = await import("/pagefind/pagefind.js");
  await pagefind.options({
    ranking: {
      termSimilarity: 2,
    },
  });
  await pagefind.init();

  const scoreOrgResult = (org: any, query: string) => {
    const normalizedQueries = buildSearchAliases(query).map((alias) => normalizeSearchText(alias));
    if (normalizedQueries.length === 0) return 0;

    const title = normalizeSearchText(org.meta?.title ?? "");
    const keywords = normalizeSearchText(org.meta?.keywords ?? "");
    const kana = normalizeSearchText(org.meta?.kana ?? "");

    return normalizedQueries.reduce((bestScore, normalizedQuery) => {
      let score = 0;

      if (title === normalizedQuery) score += 300;
      if (title.startsWith(normalizedQuery)) score += 180;
      if (title.includes(normalizedQuery)) score += 120;
      if (keywords.includes(normalizedQuery)) score += 80;
      if (kana === normalizedQuery) score += 240;
      if (kana.startsWith(normalizedQuery)) score += 180;
      if (kana.includes(normalizedQuery)) score += 120;

      return Math.max(bestScore, score);
    }, 0);
  };

  let lastSearchQuery = "";
  let lastSearchIds: string[] | null = null;
  let latestSearchToken = 0;
  let latestApplyToken = 0;
  let debounceTimer: number | undefined;

  const getSearchResultIds = async (query: string, forceRefresh = false) => {
    if (!forceRefresh && query === lastSearchQuery && lastSearchIds !== null) {
      return lastSearchIds;
    }

    const token = ++latestSearchToken;
    const aliases = buildSearchAliases(query);
    if (aliases.length === 0) {
      lastSearchQuery = query;
      lastSearchIds = [];
      return [];
    }

    const searches = await Promise.all(
      aliases.map(async (alias, aliasIndex) => {
        const searchResults = await pagefind.search(alias);
        return searchResults.results.map((result: any, resultIndex: number) => ({
          result,
          aliasIndex,
          resultIndex,
        }));
      })
    );

    const mergedResults = new Map<string, { org: any; rank: number }>();

    for (const resultGroup of searches) {
      for (const { result, aliasIndex, resultIndex } of resultGroup) {
        const rank = aliasIndex * 1000 + resultIndex;
        const url = result.url as string;
        const existing = mergedResults.get(url);
        if (existing && existing.rank <= rank) continue;

        mergedResults.set(url, {
          org: await result.data(),
          rank,
        });
      }
    }

    const rankedOrgs = [...mergedResults.values()]
      .map(({ org, rank }) => ({
        org,
        rank,
        score: scoreOrgResult(org, query),
      }))
      .sort((a, b) => b.score - a.score || a.rank - b.rank)
      .map(({ org }) => org);

    const ids = rankedOrgs
      .map<string>((org) => org.url)
      .flatMap((url) => {
        const match = url.match(/orgs\/([^/]+)/);
        return match ? match[1] : null;
      })
      .filter((id) => id !== null)
      .filter((id, index, ids) => ids.indexOf(id) === index);

    if (token !== latestSearchToken) {
      return null;
    }

    lastSearchQuery = query;
    lastSearchIds = ids;
    return ids;
  };

  const getSelectedCategories = () => categoryInputs.filter((input) => input.checked).map((input) => input.value);

  const updateUrl = () => {
    const query = text.value.trim();
    const selectedCategories = getSelectedCategories();
    const url = new URL(window.location.href);

    url.searchParams.delete("q");
    url.searchParams.delete("c[]");
    url.searchParams.delete("f");

    if (query !== "") {
      url.searchParams.set("q", query);
    }

    if (selectedCategories.length === 0) {
      url.searchParams.append("c[]", "");
    } else if (selectedCategories.length < categoryInputs.length) {
      for (const category of selectedCategories) {
        url.searchParams.append("c[]", category);
      }
    }

    if (favoriteCheckbox.checked) {
      url.searchParams.set("f", "1");
    }

    const nextUrl = `${url.pathname}${url.search}${url.hash}`;
    window.history.replaceState({}, "", nextUrl);
  };

  const applyFilters = async (forceSearch = false) => {
    const applyToken = ++latestApplyToken;
    const query = text.value.trim();
    const selectedCategories = new Set(getSelectedCategories());
    const favoriteIds = favoriteCheckbox.checked ? getFavoriteIds() : null;

    updateFavoriteLabel();
    updateUrl();

    let orderedIds = originalOrderIds;
    if (query !== "") {
      const ids = await getSearchResultIds(query, forceSearch);
      if (applyToken !== latestApplyToken || ids === null) {
        return;
      }
      orderedIds = ids;
    }

    const visibleIds = orderedIds.filter((id) => {
      const card = cardMap.get(id);
      if (!card) return false;

      const category = card.dataset.orgCategory ?? "";
      const matchesCategory = selectedCategories.has(category);
      const matchesFavorite = favoriteIds ? favoriteIds.has(id) : true;

      return matchesCategory && matchesFavorite;
    });

    const visibleIdSet = new Set(visibleIds);
    const orderedCards = visibleIds
      .map((id) => cardMap.get(id))
      .filter((card): card is HTMLElement => card !== undefined);
    const hiddenCards = originalOrderIds
      .filter((id) => !visibleIdSet.has(id))
      .map((id) => cardMap.get(id))
      .filter((card): card is HTMLElement => card !== undefined);

    for (const card of [...orderedCards, ...hiddenCards]) {
      card.hidden = !visibleIdSet.has(card.dataset.orgId!);
      grid.appendChild(card);
    }

    if (isInitialPending) {
      grid.hidden = false;
      grid.removeAttribute("data-initial-search-pending");
      loading.hidden = true;
    }

    emptyState.hidden = visibleIds.length !== 0;
  };

  const debounceApplyFilters = () => {
    if (debounceTimer) {
      clearTimeout(debounceTimer);
    }

    debounceTimer = window.setTimeout(() => {
      applyFilters();
    }, 200);
  };

  text.addEventListener("input", () => {
    const query = text.value.trim();
    if (query.length > 0) {
      buildSearchAliases(query).forEach((alias) => pagefind.preload(alias));
    } else {
      lastSearchQuery = "";
      lastSearchIds = null;
    }

    debounceApplyFilters();
  });

  for (const input of categoryInputs) {
    input.addEventListener("change", () => {
      applyFilters();
    });
  }

  favoriteCheckbox.addEventListener("change", () => {
    applyFilters();
  });

  search.addEventListener("submit", (e) => {
    e.preventDefault();
    applyFilters(true);
  });

  window.addEventListener("favoritegroupschange", () => {
    updateFavoriteLabel();
    applyFilters();
  });

  applyFilters();
</script>
